# ./roles/prometheus_stack/templates/prometheus-values.yaml.j2
prometheus:
  prometheusSpec:
    scrapeInterval: "1m"
    evaluationInterval: "1m"
    nodeSelector:
      kubernetes.io/hostname: "{{ target_worker_node }}"
    externalLabels:
      cluster_id: "finops-k3s"

    # 데이터 보관 기간 및 스토리지 설정
    retention: 10d  # 10일치 데이터만 보관 
    storageSpec:
      volumeClaimTemplate:
        spec:
          # storageClassName: "gp3" # AWS EBS를 직접 쓰려면 주석 해제 (CSI 필요)
          accessModes: ["ReadWriteOnce"]
          resources:
            requests:
              storage: 5Gi 

    resources:
      requests:
        cpu: "200m"
        memory: "512Mi"
      limits:
        cpu: "500m"
        memory: "1Gi"
    
    # 다른 네임스페이스의 모니터링 규칙과 타겟을 모두 인식하도록 제한 해제
    serviceMonitorSelectorNilUsesHelmValues: false
    ruleSelectorNilUsesHelmValues: false

prometheusOperator:
  nodeSelector:
    kubernetes.io/hostname: "{{ target_worker_node }}"
    

prometheus-node-exporter:
  prometheus:
    monitor:
      enabled: true
      relabelings:
        - sourceLabels: [__meta_kubernetes_pod_node_name]
          targetLabel: node
          action: replace
        - sourceLabels: [__meta_kubernetes_pod_node_name]
          targetLabel: instance
          action: replace