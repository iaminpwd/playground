      "targets": [{"datasource": {"type": "prometheus","uid": "prometheus"},"editorMode": "code","expr": "min(\n  (\n    sum(kube_node_status_allocatable{resource=\"cpu\"}) by (node)\n    - sum(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])) by (node)\n  )\n  / sum(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])) by (node)\n) * 3600","legendFormat": "Time to Scale","range": true,"refId": "A"}],
