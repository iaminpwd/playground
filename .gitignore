cat <<EOF > .gitignore
# Terraform/Terragrunt 임시 폴더 (절대 올리면 안 됨)
.terragrunt-cache/
.terraform/
**/.terragrunt-cache/
**/.terraform/

# 상태 파일 (나중에 원격 백엔드로 관리해야 함)
*.tfstate
*.tfstate.*

# 변수 파일 (비밀번호 등이 들어있을 수 있음)
*.tfvars
*.tfvars.json
root.hcl  # 아까 민감한 정보 넣으셨다면 이것도 제외 추천

# 로그 및 기타
.terraform.lock.hcl
*.log
EOF