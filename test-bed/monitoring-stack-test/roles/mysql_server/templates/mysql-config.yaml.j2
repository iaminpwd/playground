apiVersion: v1
kind: Secret
metadata:
  name: mysql-secret
type: Opaque
data:
  # 비밀번호: admin123 (echo -n 'admin123' | base64)
  # 앤서블 b64encode 필터를 사용하여 안전하게 인코딩합니다.
  mysql-root-password: {{ 'admin123' | b64encode }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: mysql-exporter-cfg
data:
  # [핵심 수정] 엑스포터가 파일로 읽어갈 수 있도록 .my.cnf 형식을 사용합니다.
  my.cnf: |
    [client]
    user=root
    password=admin123
    host=localhost
    port=3306