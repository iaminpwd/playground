global:
  scrape_interval: 15s
  external_labels:
    cluster: "k3s-cluster"

scrape_configs:
  # 1. 노드 하드웨어 메트릭 (Node Exporter)
  - job_name: 'kubernetes-nodes-exporter'
    kubernetes_sd_configs:
      - role: node
    relabel_configs:
      - action: replace
        source_labels: [__address__]
        regex: '(.*):10250'
        replacement: '${1}:9100'
        target_label: __address__
      - source_labels: [__meta_kubernetes_node_name]
        target_label: instance

  # 2. K3S 클러스터 상태 메트릭 (kube-state-metrics)
  - job_name: 'kube-state-metrics'
    static_configs:
      - targets: ['kube-state-metrics.monitoring.svc.cluster.local:8080']

  # 3. 컨테이너 리소스 메트릭 (cAdvisor via API Proxy)
  - job_name: 'kubernetes-nodes'
    scheme: https
    tls_config:
      ca_file: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
      insecure_skip_verify: true
    bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
    kubernetes_sd_configs:
      - role: node
    relabel_configs:
      - action: labelmap
        regex: __meta_kubernetes_node_label_(.+)
      - target_label: __address__
        replacement: kubernetes.default.svc:443
      - source_labels: [__meta_kubernetes_node_name]
        regex: (.+)
        target_label: __metrics_path__
        replacement: /api/v1/nodes/${1}/proxy/metrics/cadvisor
      - source_labels: [__meta_kubernetes_node_name]
        target_label: instance

  # 4. [추가] Nginx 사이드카 익스포터 (default 네임스페이스)
  - job_name: 'nginx-exporter'
    kubernetes_sd_configs:
      - role: pod
        namespaces:
          names: ['default']
    relabel_configs:
      # 파드 이름이 nginx-web으로 시작하는 것만 필터링
      - source_labels: [__meta_kubernetes_pod_name]
        action: keep
        regex: nginx-web.*
      # 파드 IP를 유지하면서 포트만 9113으로 변경
      - source_labels: [__address__]
        regex: ([^:]+)(?::\d+)?
        replacement: ${1}:9113
        target_label: __address__
      # 대시보드에서 파드 이름을 확인할 수 있게 instance로 지정
      - source_labels: [__meta_kubernetes_pod_name]
        target_label: instance

  # 5. [추가] MySQL 사이드카 익스포터 (default 네임스페이스)
  - job_name: 'mysql-exporter'
    kubernetes_sd_configs:
      - role: pod
        namespaces:
          names: ['default']
    relabel_configs:
      # 파드 이름이 mysql-db로 시작하는 것만 필터링
      - source_labels: [__meta_kubernetes_pod_name]
        action: keep
        regex: mysql-db.*
      # 파드 IP를 유지하면서 포트만 9104로 변경
      - source_labels: [__address__]
        regex: ([^:]+)(?::\d+)?
        replacement: ${1}:9104
        target_label: __address__
      - source_labels: [__meta_kubernetes_pod_name]
        target_label: instance

remote_write:
  - url: "http://192.168.56.20:9090/api/v1/write"